<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>DebtorsOutstanding</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY></SVCURRENTCOMPANY>
                <SVFROMDATE></SVFROMDATE>
                <SVTODATE></SVTODATE>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="DebtorsOutstanding" ISMODIFY="No">
                        <TYPE>Bill</TYPE>
                        <CHILDOF>$$GroupSundryDebtors</CHILDOF>
                        <FETCH>NAME</FETCH>
                        <FETCH>BILLDATE</FETCH>
                        <FETCH>PARENT</FETCH>
                        <FETCH>CLOSINGBALANCE</FETCH>
                        <FETCH>BILLDUEDATE</FETCH>
                    </COLLECTION>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>