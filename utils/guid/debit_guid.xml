<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>DebitNoteGUIDs</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY></SVCURRENTCOMPANY>
                <SVFROMDATE TYPE="Date"></SVFROMDATE>
                <SVTODATE TYPE="Date"></SVTODATE>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="DebitNoteGUIDs">
                        <TYPE>Voucher</TYPE>
                        <CHILDOF>$$VchTypeDebitNote</CHILDOF>
                        <FETCH>GUID</FETCH>
                        <FETCH>VOUCHERKEY</FETCH>
                        <FETCH>DATE</FETCH>
                        <FETCH>VOUCHERNUMBER</FETCH>
                    </COLLECTION>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>
