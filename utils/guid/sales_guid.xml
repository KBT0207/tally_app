<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>SalesVoucherGUIDs</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY></SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="SalesVoucherGUIDs">
                        <TYPE>Voucher</TYPE>
                        <FILTER>IsSalesCategory</FILTER>
                        <FILTER>IsNotOptional</FILTER>
                        
                        <FETCH>GUID</FETCH>
                        <FETCH>VOUCHERKEY</FETCH>
                        <FETCH>DATE</FETCH>
                        <FETCH>VOUCHERNUMBER</FETCH>
                        <FETCH>VOUCHERTYPENAME</FETCH>
                    </COLLECTION>

                    <SYSTEM TYPE="Formulae" NAME="IsSalesCategory">$$IsSales:$VoucherTypeName</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="IsNotOptional">NOT $IsOptional</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>