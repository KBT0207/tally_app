<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>CreditNoteGUIDs</ID>
    </HEADER>
    <BODY>
        <DESC>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="CreditNoteGUIDs">
                        <TYPE>Voucher</TYPE>
                        <FILTER>IsCreditNoteCategory, IsNotOptional</FILTER>
                        <FETCH>GUID, VOUCHERKEY, DATE, VOUCHERNUMBER, VOUCHERTYPENAME</FETCH>
                    </COLLECTION>
                    <SYSTEM TYPE="Formulae" NAME="IsCreditNoteCategory">$$IsCreditNote:$VoucherTypeName</SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="IsNotOptional">NOT $IsOptional</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>