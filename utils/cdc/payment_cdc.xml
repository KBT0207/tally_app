<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>IncrementalPaymentVouchers</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>COMPANY_NAME_HERE</SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="IncrementalPaymentVouchers">
                        <TYPE>Voucher</TYPE>
                        <CHILDOF>$$VchTypePayment</CHILDOF>
                        <FILTER>AlterIdFilter</FILTER>
                        <FILTER>IsPaymentFilter</FILTER>

                        <FETCH>GUID</FETCH>
                        <FETCH>ALTERID</FETCH>
                        <FETCH>MASTERID</FETCH>
                        <FETCH>VOUCHERNUMBER</FETCH>
                        <FETCH>VOUCHERTYPENAME</FETCH>
                        <FETCH>DATE</FETCH>
                        <FETCH>REFERENCE</FETCH>
                        <FETCH>NARRATION</FETCH>
                        <!-- Ledger Entry Fields -->
                        <FETCH>ALLLEDGERENTRIES.LEDGERNAME</FETCH>
                        <FETCH>ALLLEDGERENTRIES.AMOUNT</FETCH>
                    </COLLECTION>
                    <SYSTEM TYPE="Formulae" NAME="AlterIdFilter">
                        $ALTERID &gt; PLACEHOLDER_ALTER_ID
                    </SYSTEM>
                    <SYSTEM TYPE="Formulae" NAME="IsPaymentFilter">
                        $$IsPayment:$VoucherTypeName
                    </SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>