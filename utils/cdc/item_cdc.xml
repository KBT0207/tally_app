<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>IncrementalStockItems</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY></SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="IncrementalStockItems" ISMODIFY="No">
                        <TYPE>StockItem</TYPE>
                        <FILTER>AlterIdFilter</FILTER>

                        <FETCH>GUID</FETCH>
                        <FETCH>ALTERID</FETCH>
                        <FETCH>REMOTEALTGUID</FETCH>
                        <FETCH>NAME</FETCH>
                        <FETCH>PARENT</FETCH>
                        <FETCH>CATEGORY</FETCH>
                        <FETCH>BASEUNITS</FETCH>
                        <FETCH>GSTTYPEOFSUPPLY</FETCH>
                        <FETCH>OPENINGBALANCE</FETCH>
                        <FETCH>OPENINGRATE</FETCH>
                        <FETCH>OPENINGVALUE</FETCH>
                        <FETCH>ENTEREDBY</FETCH>
                        <FETCH>ISDELETED</FETCH>
                    </COLLECTION>
                    <SYSTEM TYPE="Formulae" NAME="AlterIdFilter">
                        $ALTERID > PLACEHOLDER_ALTER_ID
                    </SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>
