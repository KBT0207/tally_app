<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>StockItemCDC</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="StockItemCDC">
                        <TYPE>StockItem</TYPE>

                        <!-- Core -->
                        <FETCH>NAME</FETCH>
                        <FETCH>PARENT</FETCH>
                        <FETCH>CATEGORY</FETCH>
                        <FETCH>BASEUNITS</FETCH>
                        <FETCH>GSTTYPEOFSUPPLY</FETCH>
                        <FETCH>ENTEREDBY</FETCH>
                        <FETCH>GUID</FETCH>
                        <FETCH>REMOTEALTGUID</FETCH>
                        <FETCH>ALTERID</FETCH>
                        <FETCH>ISDELETED</FETCH>

                        <!-- Opening -->
                        <FETCH>OPENINGBALANCE</FETCH>
                        <FETCH>OPENINGRATE</FETCH>
                        <FETCH>OPENINGVALUE</FETCH>

                        <!-- GST -->
                        <FETCH>GSTDETAILS.LIST</FETCH>
                        <FETCH>APPLICABLEFROM</FETCH>
                        <FETCH>HSNCODE</FETCH>
                        <FETCH>TAXABILITY</FETCH>
                        <FETCH>RATEDETAILS.LIST</FETCH>
                        <FETCH>GSTRATEDUTYHEAD</FETCH>
                        <FETCH>GSTRATE</FETCH>

                    </COLLECTION>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>